<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Minimal entitlements for Phase-0 spike. SystemConfiguration-specific
         entitlements (e.g. com.apple.SystemConfiguration.SCPreferences-write-access)
         may need to be added if SCPreferencesCommitChanges/ApplyChanges is denied
         at runtime; they are intentionally omitted for this first test. -->
    <key>platform-application</key>
    <true/>
    <key>com.apple.private.security.no-sandbox</key>
    <true/>
    <key>keychain-access-groups</key>
    <array>
        <string>io.ymuu.proxyswitcherng</string>
    </array>
</dict>
</plist>
