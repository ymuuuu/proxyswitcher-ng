<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>title</key>
	<string>ProxySwitcher</string>
	<key>items</key>
	<array>
		<dict>
			<key>cell</key><string>PSGroupCell</string>
			<key>footerText</key><string>Toggle the Wi-Fi HTTP/HTTPS proxy. Changes apply immediately and persist across network switches.</string>
		</dict>
		<dict>
			<key>cell</key><string>PSSwitchCell</string>
			<key>default</key><true/>
			<key>defaults</key><string>io.ymuu.proxyswitcherng</string>
			<key>key</key><string>enabled</string>
			<key>label</key><string>Enabled</string>
			<key>PostNotification</key><string>io.ymuu.proxyswitcherng/settingschanged</string>
		</dict>
		<dict>
			<key>cell</key><string>PSSwitchCell</string>
			<key>default</key><false/>
			<key>defaults</key><string>io.ymuu.proxyswitcherng</string>
			<key>key</key><string>type</string>
			<key>label</key><string>Proxy</string>
			<key>PostNotification</key><string>io.ymuu.proxyswitcherng/settingschanged</string>
		</dict>
		<dict>
			<key>cell</key><string>PSGroupCell</string>
			<key>label</key><string>Proxy Server</string>
		</dict>
		<dict>
			<key>cell</key><string>PSEditTextCell</string>
			<key>defaults</key><string>io.ymuu.proxyswitcherng</string>
			<key>key</key><string>server</string>
			<key>label</key><string>Server</string>
			<key>isURL</key><true/>
			<key>noAutoCorrect</key><true/>
			<key>PostNotification</key><string>io.ymuu.proxyswitcherng/settingschanged</string>
		</dict>
		<dict>
			<key>cell</key><string>PSEditTextCell</string>
			<key>defaults</key><string>io.ymuu.proxyswitcherng</string>
			<key>key</key><string>port</string>
			<key>label</key><string>Port</string>
			<key>isNumeric</key><true/>
			<key>noAutoCorrect</key><true/>
			<key>keyboard</key><string>NumberPad</string>
			<key>PostNotification</key><string>io.ymuu.proxyswitcherng/settingschanged</string>
		</dict>
	</array>
</dict>
</plist>
